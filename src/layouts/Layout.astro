---
import '@/styles/global.css';
import { site } from '@/config/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.title, description = site.description } = Astro.props;
const pageTitle = `${site.name} | ${title}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(`${import.meta.env.BASE_URL}og-image.svg`, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.name,
  jobTitle: site.title,
  url: site.url,
  email: site.email,
  telephone: site.phone,
  description: site.description,
  sameAs: [site.linkedin],
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{pageTitle}</title>

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.title} — ${site.name}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={`${site.title} — ${site.name}`} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="cursor-retro">
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
  </body>
</html>

<script>
  // Protección básica anti-copia (heredada de la versión anterior):
  // se permite seleccionar/copiar solo en enlaces de contacto y zonas marcadas.
  const selectableSelector =
    'a[href^="mailto:"], a[href^="tel:"], input, textarea, [data-selectable]';

  function isSelectableTarget(target: EventTarget | null) {
    return target instanceof Element && Boolean(target.closest(selectableSelector));
  }

  function selectionIsSelectable() {
    const selection = document.getSelection();
    if (!selection || selection.isCollapsed) return false;

    const node = selection.anchorNode;
    const element =
      node?.nodeType === Node.TEXT_NODE ? node.parentElement : (node as Element | null);

    return element ? Boolean(element.closest(selectableSelector)) : false;
  }

  document.addEventListener('contextmenu', (e) => {
    if (!isSelectableTarget(e.target)) e.preventDefault();
  });

  document.addEventListener('copy', (e) => {
    if (!selectionIsSelectable()) e.preventDefault();
  });

  document.addEventListener('cut', (e) => {
    e.preventDefault();
  });

  document.addEventListener('dragstart', (e) => {
    if (!isSelectableTarget(e.target)) e.preventDefault();
  });

  document.addEventListener('keydown', (e) => {
    if (!(e.ctrlKey || e.metaKey)) return;

    const key = e.key.toLowerCase();

    if (key === 'c' || key === 'x') {
      if (!selectionIsSelectable() && !isSelectableTarget(e.target)) {
        e.preventDefault();
      }
      return;
    }

    if (key === 's' || key === 'u') {
      e.preventDefault();
    }
  });
</script>
