---
import type { CardTone, IconName } from '@/types/theme';

export interface Project {
  title: string;
  description: string;
  icon: IconName;
  tone: CardTone;
  image?: string;
  imageAlt?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
const carouselId = `projects-carousel-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class="projects-carousel"
  data-projects-carousel
  id={carouselId}
  role="region"
  aria-roledescription="carrusel"
  aria-label="Proyectos recientes"
>
  <div
    class="projects-carousel__viewport"
    data-carousel-viewport
    tabindex="0"
    aria-label="Desliza o usa las flechas para ver más proyectos"
  >
    <div class="projects-carousel__container">
      {
        projects.map((project, index) => (
          <article
            class:list={['projects-carousel__slide', index === 0 && 'is-active']}
            data-carousel-slide
            data-title={project.title}
            aria-hidden={index !== 0}
          >
            <div class:list={['bento-card group projects-carousel__card', `bento-card--${project.tone}`]}>
              <div class="bento-card-accent" aria-hidden="true" />
              <div class="bento-card-glow" aria-hidden="true" />

              <div class="projects-carousel__card-inner">
                <div class="projects-carousel__content">
                  <h3 class="content-card-title">{project.title}</h3>
                  <div class="projects-carousel__description-group">
                    {
                      project.description
                        .split('\n')
                        .map((part) => part.trim())
                        .filter(Boolean)
                        .map((paragraph) => (
                          <p class="content-card-text projects-carousel__description">{paragraph}</p>
                        ))
                    }
                  </div>
                </div>

                <div class:list={['projects-carousel__media', `projects-carousel__media--${project.tone}`]}>
                  {
                    project.image ? (
                      <img
                        src={project.image}
                        alt={project.imageAlt ?? project.title}
                        class="projects-carousel__image"
                        loading="lazy"
                        decoding="async"
                        draggable="false"
                      />
                    ) : (
                      <div class="projects-carousel__placeholder" aria-hidden="true">
                        <svg
                          class="projects-carousel__placeholder-icon"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1.5"
                        >
                          <rect x="3" y="5" width="18" height="14" rx="2" />
                          <circle cx="8.5" cy="10" r="1.5" fill="currentColor" stroke="none" />
                          <path d="M3 16l5-5 4 4 3-3 6 6" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <span class="projects-carousel__placeholder-label">Imagen del proyecto</span>
                      </div>
                    )
                  }
                </div>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>

  <div class="projects-carousel__controls">
    <button
      type="button"
      class="projects-carousel__nav"
      data-carousel-prev
      aria-controls={carouselId}
      aria-label="Proyecto anterior"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>

    <div class="projects-carousel__dots" role="tablist" aria-label="Seleccionar proyecto">
      {
        projects.map((project, index) => (
          <button
            type="button"
            class:list={['projects-carousel__dot', index === 0 && 'is-active']}
            data-carousel-dot={index}
            role="tab"
            aria-selected={index === 0}
            aria-label={project.title}
            tabindex={index === 0 ? 0 : -1}
          />
        ))
      }
    </div>

    <button
      type="button"
      class="projects-carousel__nav"
      data-carousel-next
      aria-controls={carouselId}
      aria-label="Proyecto siguiente"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
  </div>

  <p class="projects-carousel__status sr-only" data-carousel-status aria-live="polite">
    Proyecto 1 de {projects.length}: {projects[0].title}
  </p>
</div>

<script>
  import EmblaCarousel, { type EmblaCarouselType } from 'embla-carousel';

  const carouselInstances = new WeakMap<HTMLElement, EmblaCarouselType>();

  function initProjectsCarousels() {
    document.querySelectorAll<HTMLElement>('[data-projects-carousel]').forEach((root) => {
      const existing = carouselInstances.get(root);
      if (existing) {
        existing.destroy();
        carouselInstances.delete(root);
      }

      const viewport = root.querySelector<HTMLElement>('[data-carousel-viewport]');
      const prevBtn = root.querySelector<HTMLButtonElement>('[data-carousel-prev]');
      const nextBtn = root.querySelector<HTMLButtonElement>('[data-carousel-next]');
      const dots = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-carousel-dot]'));
      const status = root.querySelector<HTMLElement>('[data-carousel-status]');

      if (!viewport || !prevBtn || !nextBtn) return;

      const embla = EmblaCarousel(viewport, {
        loop: true,
        align: 'center',
        containScroll: false,
        dragFree: false,
      });

      carouselInstances.set(root, embla);

      const slides = embla.slideNodes();

      function getTitle(index: number) {
        return (slides[index] as HTMLElement | undefined)?.dataset.title ?? '';
      }

      function updateState() {
        const selected = embla.selectedScrollSnap();
        const total = slides.length;

        slides.forEach((slide, index) => {
          const isActive = index === selected;
          slide.classList.toggle('is-active', isActive);
          slide.setAttribute('aria-hidden', isActive ? 'false' : 'true');
        });

        dots.forEach((dot, index) => {
          const isActive = index === selected;
          dot.classList.toggle('is-active', isActive);
          dot.setAttribute('aria-selected', String(isActive));
          dot.tabIndex = isActive ? 0 : -1;
        });

        if (status) {
          status.textContent = `Proyecto ${selected + 1} de ${total}: ${getTitle(selected)}`;
        }
      }

      prevBtn.addEventListener('click', () => embla.scrollPrev());
      nextBtn.addEventListener('click', () => embla.scrollNext());

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const index = Number(dot.dataset.carouselDot);
          if (!Number.isNaN(index)) embla.scrollTo(index);
        });
      });

      viewport.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          embla.scrollPrev();
        } else if (event.key === 'ArrowRight') {
          event.preventDefault();
          embla.scrollNext();
        } else if (event.key === 'Home') {
          event.preventDefault();
          embla.scrollTo(0);
        } else if (event.key === 'End') {
          event.preventDefault();
          embla.scrollTo(slides.length - 1);
        }
      });

      embla.on('select', updateState);
      embla.on('reInit', updateState);
      updateState();
    });
  }

  initProjectsCarousels();
  document.addEventListener('astro:page-load', initProjectsCarousels);
</script>
