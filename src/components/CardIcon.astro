---
import type { IconName, IconTone } from '@/types/theme';

interface Props {
  name: IconName;
  tone?: IconTone;
  compact?: boolean;
}

const { name, tone = 'sky', compact = false } = Astro.props;

const toneClasses: Record<IconTone, string> = {
  sky: 'bg-sky-500/15 text-sky-300 ring-sky-400/20',
  violet: 'bg-violet-500/15 text-violet-300 ring-violet-400/20',
  teal: 'bg-teal-500/15 text-teal-300 ring-teal-400/20',
  amber: 'bg-amber-500/15 text-amber-300 ring-amber-400/20',
  rose: 'bg-rose-500/15 text-rose-300 ring-rose-400/20',
  cyan: 'bg-cyan-500/15 text-cyan-300 ring-cyan-400/20',
};

const paths: Record<IconName, string> = {
  agents:
    'M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a2 2 0 1 1 0 4h-1.05A7 7 0 0 1 14 22h-4a7 7 0 0 1-6.95-4H2a2 2 0 1 1 0-4h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z',
  brain:
    'M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588 4 4 0 0 0 7.636 2.106 3 3 0 0 0 .164-1.858 3 3 0 0 0 .164-1.858 4 4 0 0 0 .556-6.588 4 4 0 0 0-2.526-5.77A3 3 0 0 0 12 5z',
  api: 'M4 7h16M4 12h10M4 17h14 M17 10l3 2-3 2',
  code: 'M16 18l6-6-6-6M8 6l-6 6 6 6',
  chat: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z',
  calendar: 'M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z',
  report: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8M16 17H8M10 9H8',
  docs: 'M4 19.5A2.5 2.5 0 0 1 6.5 17H20 M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z',
  broadcast: 'M4.9 19.1C1 15.2 1 8.8 4.9 4.9M19.1 4.9C23 8.8 23 15.1 19.1 19M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0z',
  target: 'M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18z M12 9v6M9 12h6',
  steps: 'M13 5l7 7-7 7M5 5l7 7-7 7',
  shield: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z M9 12l2 2 4-4',
};
---

<div
  class:list={[
    'inline-flex shrink-0 items-center justify-center rounded-lg ring-1',
    compact ? 'h-9 w-9' : 'mb-3 h-9 w-9',
    toneClasses[tone],
  ]}
>
  <svg
    class:list={[compact ? 'h-4 w-4' : 'h-4 w-4']}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.75"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d={paths[name]} />
  </svg>
</div>
