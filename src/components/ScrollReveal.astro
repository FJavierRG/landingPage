---
interface Props {
  class?: string;
  delay?: number;
  tag?: keyof HTMLElementTagNameMap;
}

const { class: className = '', delay = 0, tag: Tag = 'div' } = Astro.props;
---

<Tag
  class:list={['reveal', className]}
  style={delay > 0 ? `transition-delay: ${delay}ms` : undefined}
>
  <slot />
</Tag>
