---
import { site } from '@/config/site';

const navLinks = [
  { href: '#servicios', label: 'Servicios' },
  { href: '#proyectos', label: 'Proyectos' },
  { href: '#enfoque', label: 'Enfoque' },
  { href: '#contacto', label: 'Contacto' },
];
---

<header class="sticky top-0 z-50 border-b border-white/[0.06] bg-surface/75 backdrop-blur-xl">
  <div class="container-wide flex items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
    <a
      href={import.meta.env.BASE_URL}
      class="text-sm font-semibold tracking-tight text-ink transition hover:text-accent sm:text-base"
    >
      {site.name}
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Principal">
      {
        navLinks.map((link) => (
          <a href={link.href} class="nav-link">
            {link.label}
          </a>
        ))
      }
    </nav>

    <a href="#contacto" class="btn-primary hidden !px-4 !py-2 text-xs md:inline-flex">
      Contactar
    </a>

    <button
      type="button"
      id="menu-toggle"
      class="inline-flex items-center justify-center rounded-xl border border-white/[0.08] bg-white/[0.03] p-2.5 text-ink-muted transition hover:border-white/15 hover:text-ink md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Abrir menú"
    >
      <svg id="icon-open" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
      </svg>
      <svg id="icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-white/[0.06] bg-surface/95 backdrop-blur-xl md:hidden"
    aria-label="Principal móvil"
  >
    <div class="flex flex-col gap-1 px-4 py-3 sm:px-6">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link rounded-xl px-3 py-3 text-sm text-ink-muted transition hover:bg-white/[0.04] hover:text-ink"
          >
            {link.label}
          </a>
        ))
      }
      <a href="#contacto" class="mobile-nav-link btn-primary mt-2 !py-3 text-center">
        Contactar
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');
  const links = document.querySelectorAll('.mobile-nav-link');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });

  links.forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    });
  });
</script>
