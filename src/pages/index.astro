---
import Layout from '@/layouts/Layout.astro';
import Window from '@/components/retro/Window.astro';
import PixelIcon from '@/components/retro/PixelIcon.astro';
import { site } from '@/config/site';
import contenido from '@/config/contenido.json';

const { ventanas, barraTareas, arranque } = contenido;
const base = import.meta.env.BASE_URL;

const iconos = [
  { target: 'win-trabajos', label: ventanas.trabajos.etiquetaIcono, kind: 'carpeta' },
  { target: 'win-proyectos', label: ventanas.proyectos.etiquetaIcono, kind: 'carpeta' },
  { target: 'win-sobre-mi', label: ventanas['sobre-mi'].etiquetaIcono, kind: 'doc' },
  { target: 'win-contacto', label: ventanas.contacto.etiquetaIcono, kind: 'sobre' },
] as const;

const telHref = 'tel:' + site.phone.replace(/\s/g, '');
---

<Layout>
  <!-- Cuadrícula del escritorio dibujada ya curvada (capa sin texto: se puede doblar) -->
  <canvas id="bg-grid" aria-hidden="true"></canvas>

  <div id="desk">
    <!-- Decoración del escritorio -->
    <div class="desk-deco" aria-hidden="true">
      <span class="bits" style="top: 6%; right: 12%;">0110100101</span>
      <span class="bits" style="top: 40%; right: 5%;">1010011010</span>
      <span class="bits" style="bottom: 14%; left: 16%;">0011010110</span>
      <span class="cross" style="top: 12%; right: 28%;">×</span>
      <span class="cross" style="bottom: 22%; right: 18%;">×</span>
      <span class="cross" style="top: 58%; left: 3%;">×</span>
      <div class="frame" style="top: 8%; right: 6%; width: 130px; height: 70px;"></div>
      <div class="frame" style="bottom: 12%; right: 30%; width: 90px; height: 90px;"></div>
    </div>

    <!-- Iconos de escritorio -->
    <nav class="icons" aria-label="Accesos directos">
      {
        iconos.map((icono) => (
          <button class="icon" data-opens={icono.target} title={icono.label}>
            <PixelIcon kind={icono.kind} />
            <span class="label">{icono.label}</span>
          </button>
        ))
      }
    </nav>

    <!-- Ventana: trabajos -->
    <Window id="win-trabajos" title={ventanas.trabajos.titulo} class="win-trabajos">
      {
        ventanas.trabajos.entradas.map((job) => (
          <div class="job">
            <b>{job.periodo}</b> · {job.texto}
          </div>
        ))
      }
    </Window>

    <!-- Ventana: explorador de proyectos -->
    <Window id="win-proyectos" title={ventanas.proyectos.titulo} class="win-proyectos">
      <div class="files">
        {
          ventanas.proyectos.items.map((p) => (
            <button class="file" data-opens={`win-proyecto-${p.id}`} title={p.titulo}>
              <PixelIcon kind="carpeta" size="sm" />
              <span>{p.etiquetaArchivo}</span>
            </button>
          ))
        }
      </div>
    </Window>

    <!-- Ventanas de cada proyecto -->
    {
      ventanas.proyectos.items.map((p, i) => (
        <Window
          id={`win-proyecto-${p.id}`}
          title={`proyectos/${p.id}.txt`}
          class="win-proyecto"
          style={`margin-top: ${i * 3}vh;`}
        >
          <h1>{p.titulo}</h1>
          {p.imagen && (
            <div class="proyecto-img">
              <img src={`${base}${p.imagen}`} alt={p.alt} loading="lazy" />
            </div>
          )}
          {p.parrafos.map((texto) => (
            <p>{texto}</p>
          ))}
        </Window>
      ))
    }

    <!-- Ventana: sobre mí -->
    <Window id="win-sobre-mi" title={ventanas['sobre-mi'].titulo} class="win-sobre-mi">
      <h1>{site.name}</h1>
      <p class="meta">{ventanas['sobre-mi'].meta}</p>
      {ventanas['sobre-mi'].parrafos.map((texto) => <p>{texto}</p>)}
      <div class="sys">{ventanas['sobre-mi'].estado}</div>
    </Window>

    <!-- Ventana: contacto -->
    <Window id="win-contacto" title={ventanas.contacto.titulo} class="win-contacto">
      <p>{ventanas.contacto.intro}</p>
      <div style="display: grid; gap: 10px;">
        <a class="chip" href={`mailto:${site.email}`}>
          <span>{ventanas.contacto.etiquetas.email}</span>{site.email}
        </a>
        <a class="chip" href={telHref}>
          <span>{ventanas.contacto.etiquetas.telefono}</span>{site.phone}
        </a>
        <a class="chip" href={site.linkedin} target="_blank" rel="noopener">
          <span>{ventanas.contacto.etiquetas.linkedin}</span>
          {ventanas.contacto.etiquetas.linkedinValor}
        </a>
      </div>
    </Window>

    <!-- Barra de tareas -->
    <footer class="taskbar">
      <span class="start">{barraTareas.inicio}</span>
      <span>{barraTareas.sistema}</span>
      <div class="open-list" aria-label="Ventanas abiertas"></div>
      <span class="clock" id="clock">--:--</span>
    </footer>
  </div>

  <!-- Filtro SVG para el tearing: feDisplacementMap con mapa de bandas.
       Donde el mapa es neutro rgb(127,0,127) no hay desplazamiento; las bandas
       con R=255 desplazan su franja a la derecha y con R=0 a la izquierda. -->
  <svg width="0" height="0" style="position:absolute" aria-hidden="true">
    <filter id="tearFilter" x="0" y="0" width="100%" height="100%" color-interpolation-filters="sRGB">
      <feFlood flood-color="rgb(127,0,127)" result="neutral"></feFlood>
      <feFlood
        id="tear-band-a"
        flood-color="rgb(255,0,127)"
        x="0"
        width="100%"
        y="30%"
        height="0%"
        result="bandA"></feFlood>
      <feFlood
        id="tear-band-b"
        flood-color="rgb(0,0,127)"
        x="0"
        width="100%"
        y="34%"
        height="0%"
        result="bandB"></feFlood>
      <feMerge result="map">
        <feMergeNode in="neutral"></feMergeNode>
        <feMergeNode in="bandA"></feMergeNode>
        <feMergeNode in="bandB"></feMergeNode>
      </feMerge>
      <feDisplacementMap
        in="SourceGraphic"
        in2="map"
        id="tear-disp"
        scale="0"
        xChannelSelector="R"
        yChannelSelector="B"></feDisplacementMap>
    </filter>
  </svg>

  <!-- Overlay CRT -->
  <canvas id="crt" aria-hidden="true"></canvas>

  <!-- Pantalla de arranque -->
  <div id="boot" aria-hidden="true"><span class="boot-name">{arranque.nombre}</span></div>

  <!-- Marco físico del monitor (solo PC) -->
  <div id="bezel-tex" aria-hidden="true"></div>
  <div id="bezel" aria-hidden="true"></div>
  <div id="bezel-led" aria-hidden="true"></div>

  <!-- Sin JS: se muestran las ventanas en flujo normal, sin arranque ni efectos -->
  <noscript>
    <style>
      #boot, #crt, #bg-grid { display: none; }
      body { overflow: auto; }
      #desk { position: static; }
      .window {
        display: flex;
        position: static;
        margin: 20px auto;
        max-width: 640px;
        transform: none;
      }
      .titlebar .dot-close { visibility: hidden; }
      .taskbar { position: static; }
    </style>
  </noscript>
</Layout>

<script>
  import '@/scripts/crt';
  import '@/scripts/desktop';
</script>
